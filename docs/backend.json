
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the NexusAI ecosystem.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "avatarUrl": { "type": "string" },
        "customTag": { "type": "string" }
      },
      "required": ["id", "username", "role"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the AI chat history.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "response": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "attachments": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["senderId", "text", "status", "createdAt"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User credit balance and holdings.",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "frozenBalance": { "type": "number" },
        "currency": { "type": "string" }
      },
      "required": ["balance", "frozenBalance"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profile data."
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/ChatMessage" },
      "description": "User chat history."
    },
    "/users/{userId}/wallet/main": {
      "schema": { "$ref": "#/backend/entities/Wallet" },
      "description": "User financial data."
    },
    "/subjects/{subjectId}": {
      "schema": { "type": "object" },
      "description": "Learning subjects."
    },
    "/products/{productId}": {
      "schema": { "type": "object" },
      "description": "Marketplace items."
    }
  }
}
