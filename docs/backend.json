
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the NexusAI ecosystem.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "full_name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "avatar_url": { "type": "string" },
        "custom_tag": { "type": "string" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "response": { "type": "string" },
        "engine": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string" },
        "attachments": { "type": "array" }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "properties": {
        "balance": { "type": "number" },
        "frozenBalance": { "type": "number" },
        "currency": { "type": "string" }
      }
    },
    "MarketOffer": {
      "title": "MarketOffer",
      "properties": {
        "productId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "description": "User profiles" },
    "/users/{userId}/messages/{msgId}": { "description": "Chat history" },
    "/users/{userId}/wallet/main": { "description": "Credit balance" },
    "/users/{userId}/transactions/{txId}": { "description": "Financial ledger" },
    "/subjects/{subId}": { "description": "Learning subjects" },
    "/subjects/{subId}/collections/{colId}": { "description": "Lessons within subjects" },
    "/subjects/{subId}/collections/{colId}/learning_items/{itemId}": { "description": "Videos, documents, text in lessons" },
    "/products/{productId}": { "description": "Market items" },
    "/offers/{offerId}": { "description": "Market negotiations" },
    "/videos/{videoId}": { "description": "StreamHub videos" }
  }
}
