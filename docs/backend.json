
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the NexusAI ecosystem with Octal Hierarchy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "full_name": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["founder", "cofounder", "admin", "management", "investor", "task_executor", "free", "external_user"] 
        },
        "classification": { "type": "string", "enum": ["none", "freelancer", "investor", "manager"] },
        "proResponsesRemaining": { "type": "number", "default": 0 },
        "proTTSRemaining": { "type": "number", "default": 0 },
        "avatar_url": { "type": "string" },
        "canManageCredits": { "type": "boolean", "description": "Independent authority to distribute credits." },
        "dataConsent": { "type": "string", "enum": ["none", "agreed", "declined"], "default": "none" }
      }
    },
    "MarketOffer": {
      "title": "Market Offer",
      "properties": {
        "productId": { "type": "string" },
        "sellerId": { "type": "string" },
        "buyerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "description": "User profiles" },
    "/users/{userId}/messages/{msgId}": { "description": "AI Chat history" },
    "/users/{userId}/wallet/main": { "description": "Credit balance" },
    "/chats/{chatId}/messages/{msgId}": { "description": "Peer-to-peer messaging stream" },
    "/videos/{videoId}": { "description": "StreamHub videos" },
    "/offers/{offerId}": { "description": "Market negotiations" }
  }
}
