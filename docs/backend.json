
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the NexusAI ecosystem.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "full_name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee", "user"] },
        "classification": { "type": "string", "enum": ["none", "freelancer", "investor", "manager"], "description": "User classification assigned by admin for AI access tiers." },
        "proResponsesRemaining": { "type": "number", "default": 0, "description": "Remaining responses for restricted Pro models." },
        "proTTSRemaining": { "type": "number", "default": 0, "description": "Remaining high-quality neural voice generations." },
        "avatar_url": { "type": "string" },
        "custom_tag": { "type": "string" },
        "canManageCredits": { "type": "boolean", "description": "Independent authority to distribute credits, granted by the root admin." }
      }
    },
    "PeerMessage": {
      "title": "Peer Message",
      "description": "Direct message between two users.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "isRead": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "description": "User profiles" },
    "/users/{userId}/messages/{msgId}": { "description": "AI Chat history" },
    "/users/{userId}/wallet/main": { "description": "Credit balance" },
    "/chats/{chatId}/messages/{msgId}": { "description": "Peer-to-peer messaging stream" },
    "/videos/{videoId}": { "description": "StreamHub videos" }
  }
}
