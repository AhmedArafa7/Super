
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the NexusAI ecosystem.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "full_name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "avatar_url": { "type": "string" },
        "custom_tag": { "type": "string" }
      },
      "required": ["id", "username", "role"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the AI chat history.",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "sender_name": { "type": "string" },
        "text": { "type": "string" },
        "response": { "type": "string" },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "attachments": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["sender_id", "text", "status"]
    },
    "Video": {
      "title": "Video",
      "description": "Content in StreamHub.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "author": { "type": "string" },
        "views": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Primary user node data."
    },
    "/users/{userId}/messages/{msgId}": {
      "schema": { "$ref": "#/backend/entities/ChatMessage" },
      "description": "Neural chat streams."
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/backend/entities/Video" },
      "description": "Distributed content streams."
    },
    "/products/{productId}": {
      "schema": { "type": "object" },
      "description": "Marketplace assets."
    }
  }
}
