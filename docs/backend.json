
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the NexusAI ecosystem.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "full_name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee", "user"] },
        "avatar_url": { "type": "string" },
        "custom_tag": { "type": "string" },
        "canManageCredits": { "type": "boolean", "description": "Independent authority to distribute credits, granted by the root admin." }
      }
    },
    "Video": {
      "title": "Video",
      "description": "A broadcast clip or external link in StreamHub.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "views": { "type": "string" },
        "author": { "type": "string" },
        "source": { "type": "string", "enum": ["local", "youtube"] },
        "externalUrl": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "description": "User profiles" },
    "/users/{userId}/messages/{msgId}": { "description": "Chat history" },
    "/users/{userId}/wallet/main": { "description": "Credit balance" },
    "/users/{userId}/transactions/{txId}": { "description": "Financial ledger" },
    "/subjects/{subId}": { "description": "Learning subjects" },
    "/products/{productId}": { "description": "Market items" },
    "/offers/{offerId}": { "description": "Market negotiations" },
    "/videos/{videoId}": { "description": "StreamHub videos and broadcasts" }
  }
}
