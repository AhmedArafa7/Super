
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the NexusAI ecosystem with Octal Hierarchy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "full_name": { "type": "string" },
        "email": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["founder", "cofounder", "admin", "management", "investor", "task_executor", "free", "external_user"] 
        },
        "classification": { "type": "string", "enum": ["none", "freelancer", "investor", "manager"] },
        "proResponsesRemaining": { "type": "number", "default": 0 },
        "proTTSRemaining": { "type": "number", "default": 0 },
        "avatar_url": { "type": "string" },
        "canManageCredits": { "type": "boolean" },
        "dataConsent": { "type": "string", "enum": ["none", "agreed", "declined"], "default": "none" }
      }
    },
    "MarketItem": {
      "title": "Market Item",
      "description": "Any asset or product listed in TechMarket.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "sellerId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "mainCategory": { "type": "string" },
        "subCategory": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "sold", "pending_review", "rejected"] },
        "isLaunchable": { "type": "boolean" },
        "promoVideoUrl": { "type": "string" },
        "promoFileUrl": { "type": "string" },
        "adminFeedback": { "type": "string" }
      }
    },
    "YouTubeSubscription": {
      "title": "YouTube Subscription",
      "description": "A private YouTube channel link saved by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "channelUrl": { "type": "string" },
        "channelName": { "type": "string" },
        "channelId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "github", "password"]
  },
  "firestore": {
    "/users/{userId}": { "description": "User profiles" },
    "/users/{userId}/subscriptions/{subId}": { "description": "Private WeTube channel links" },
    "/products/{productId}": { "description": "TechMarket listings" },
    "/category_requests/{requestId}": { "description": "Global category suggestions" },
    "/offers/{offerId}": { "description": "Market negotiations" },
    "/videos/{videoId}": { "description": "WeTube visual nodes" }
  }
}
