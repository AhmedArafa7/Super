rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [SECURITY_ANCHOR: SOVEREIGN_IDENTITY_V1.5]
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    function isManagement() {
      let data = getUserData();
      return isSignedIn() && (
        data.get('role', 'free') in ['founder', 'cofounder', 'admin', 'management']
      );
    }

    function isFounder() {
      return isSignedIn() && getUserData().get('role', 'free') == 'founder';
    }

    // قواعد المستخدمين
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'free';
      allow update: if isSignedIn() && (
        isFounder() ||
        (isManagement() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['canManageCredits'])) ||
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'classification', 'canManageCredits']))
      );
      allow delete: if isFounder();
    }

    // قواعد الاشتراكات الخاصة (WeTube)
    match /users/{userId}/subscriptions/{subId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // قواعد المحادثات المباشرة (Peer Chat)
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && chatId.contains(request.auth.uid);
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && (
          chatId.contains(request.auth.uid) || isManagement()
        );
      }
    }

    // قواعد الرسائل والدردشة (AI Chat)
    match /users/{userId}/messages/{msgId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isManagement());
      allow write: if isSignedIn() && (request.auth.uid == userId || isManagement());
      allow delete: if isSignedIn() && (request.auth.uid == userId || isManagement());
    }

    // دعم استعلامات المجموعات المشتركة (Collection Groups)
    match /{path=**}/messages/{msgId} {
      allow read: if isManagement();
    }

    match /{path=**}/transactions/{txId} {
      allow read: if isManagement();
    }

    // قواعد المعاملات والمحافظ
    match /users/{userId}/transactions/{txId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isManagement());
      allow write: if isManagement() || isFounder();
    }

    match /users/{userId}/wallet/{doc=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isManagement());
      allow write: if isManagement() || isFounder();
    }

    // المنتجات والتصنيفات
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /category_requests/{requestId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /offers/{offerId} {
      allow read, write: if isSignedIn();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /app_launcher/{appId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}