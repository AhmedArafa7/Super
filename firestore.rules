
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // [STABILITY_ANCHOR: FORCE_DEPLOY_V8.6]
    // تحديث سيادي للقواعد لضمان مزامنة الفهارس المركبة الجديدة (COLLECTION_GROUP).
    
    match /{document=**} {
      allow read, write: if true;
    }

    match /{path=**}/messages/{messageId} {
      allow read, write: if true;
    }
    
    match /{path=**}/transactions/{txId} {
      allow read, write: if true;
    }
    
    match /{path=**}/collections/{colId} {
      allow read, write: if true;
    }
    
    match /{path=**}/offers/{offerId} {
      allow read, write: if true;
    }
  }
}
