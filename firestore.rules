
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // [STABILITY_ANCHOR: FORCE_DEPLOY_V8.8_FINAL]
    // نبضة نشر سيادية نهائية: تم تعميم الفهارس لتشمل النطاق الثلاثي للمتجر والفرز الزمني العالمي للعروض.
    
    match /{document=**} {
      allow read, write: if true;
    }

    match /offers/{offerId} {
      allow read, write: if true;
    }

    match /{path=**}/messages/{messageId} {
      allow read, write: if true;
    }
    
    match /{path=**}/transactions/{txId} {
      allow read, write: if true;
    }
    
    match /{path=**}/collections/{colId} {
      allow read, write: if true;
    }
    
    match /{path=**}/offers/{offerId} {
      allow read, write: if true;
    }
  }
}
