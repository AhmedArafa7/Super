rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [SECURITY_ANCHOR: SOVEREIGN_IDENTITY_V1.2]
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isManagement() {
      return isSignedIn() && (
        getUserData().role in ['founder', 'cofounder', 'admin', 'management']
      );
    }

    function isFounder() {
      return isSignedIn() && getUserData().role == 'founder';
    }

    // قواعد المستخدمين (الحماية الأساسية)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'free';
      allow update: if isSignedIn() && (
        isFounder() ||
        (isManagement() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['canManageCredits'])) ||
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'classification', 'canManageCredits']))
      );
      allow delete: if isFounder();
    }

    // قواعد المعاملات والمحافظ (دعم Collection Group)
    match /{path=**}/transactions/{txId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isManagement());
      allow write: if isManagement() || isFounder();
    }

    match /users/{userId}/wallet/{doc=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isManagement());
      allow write: if isManagement() || isFounder();
    }

    // قواعد الرسائل والدردشة (دعم Collection Group)
    match /{path=**}/messages/{msgId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isManagement());
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.userId || isManagement());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isManagement());
    }

    // المنتجات والتصنيفات
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /category_requests/{requestId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /offers/{offerId} {
      allow read, write: if isSignedIn();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /app_launcher/{appId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // المجلدات التعليمية
    match /subjects/{subId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /collections/{colId} {
        allow read, write: if isSignedIn();
        
        match /learning_items/{itemId} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // السماح بالوصول العام لبقية السجلات المؤقتاً مع وجوب تسجيل الدخول
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}