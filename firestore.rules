
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [SECURITY_ANCHOR: SOVEREIGN_IDENTITY_V1.0]
    
    // التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // جلب بيانات المستخدم الحالي من السجل
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // التحقق من رتبة الإدارة (الأدمن، المؤسس، والشركاء)
    function isManagement() {
      return isSignedIn() && (
        getUserData().role in ['founder', 'cofounder', 'admin', 'management']
      );
    }

    // التحقق من رتبة المؤسس فقط (السلطة العليا)
    function isFounder() {
      return isSignedIn() && getUserData().role == 'founder';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      
      // السماح بإنشاء الملف فقط إذا كان المعرف يطابق المستخدم المسجل والرتبة هي free
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.role == 'free';
      
      // حماية الحقول الحساسة من التعديل الذاتي
      allow update: if isSignedIn() && (
        // 1. المستخدم العادي لا يمكنه تغيير رتبته أو تصنيفه أو سلطة الائتمان
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'classification', 'canManageCredits'])) ||
        
        // 2. الإدارة يمكنها تعديل الرتب والتصنيفات ولكن لا يمكنها منح سلطة الائتمان
        (isManagement() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['canManageCredits'])) ||
        
        // 3. المؤسس له السلطة المطلقة
        isFounder()
      );
      
      allow delete: if isFounder();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /category_requests/{requestId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /offers/{offerId} {
      allow read, write: if isSignedIn();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // السماح بالوصول العام لبقية السجلات مؤقتاً مع وجوب تسجيل الدخول
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
