
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // وظائف مساعدة للتحقق من الهوية
    function isSignedIn() {
      return request.auth != null;
    }
    
    // في هذا النموذج الأولي، سنسمح بالعمليات الأساسية لضمان الاستقرار
    // مع إمكانية تضييقها لاحقاً عند الربط الفعلي بـ Firebase Auth
    
    match /users/{userId} {
      allow read, write: if true; // السماح بالوصول لبروفايل المستخدم
      
      match /messages/{messageId} {
        allow read, write: if true; // السماح بنظام الدردشة
      }
      
      match /wallet/{doc} {
        allow read, write: if true; // السماح بإدارة المحفظة
      }
    }
    
    match /videos/{videoId} {
      allow read, write: if true; // السماح بنظام ستريم هوب
    }
    
    match /subjects/{subjectId} {
      allow read, write: if true;
      match /collections/{colId} {
        allow read, write: if true;
        match /learning_items/{itemId} {
          allow read, write: if true;
        }
      }
    }
    
    match /products/{productId} {
      allow read, write: if true; // السماح للمتجر
    }
    
    match /offers/{offerId} {
      allow read, write: if true; // السماح بالعروض والمفاوضات
    }
    
    match /transactions/{txId} {
      allow read, write: if true; // سجلات التحويلات
    }
  }
}
