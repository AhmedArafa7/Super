
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // قاعدة الإنتاج المؤقتة: السماح بالوصول الكامل لضمان عمل كافة الأنظمة المدمجة
    // سيتم تقييد القواعد في مرحلة لاحقة بناءً على request.auth.uid
    match /{document=**} {
      allow read, write: if true;
    }

    // دعم البحث الشامل في الرسائل (Collection Group) الضروري للأدمن
    match /{path=**}/messages/{messageId} {
      allow read, write: if true;
    }
    
    match /{path=**}/transactions/{txId} {
      allow read, write: if true;
    }
    
    match /{path=**}/collections/{colId} {
      allow read, write: if true;
    }
    
    match /{path=**}/offers/{offerId} {
      allow read, write: if true;
    }
  }
}
