
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // قاعدة عامة للنموذج الأولي: السماح بالقراءة والكتابة للجميع لضمان عمل كافة الأنظمة داخل البيئة
    // في مرحلة الإنتاج، يتم تقييد هذه القواعد بناءً على request.auth.uid
    match /{document=**} {
      allow read, write: if true;
    }

    // دعم البحث الشامل في الرسائل (Collection Group) وهو ضروري للوحة تحكم الأدمن
    match /{path=**}/messages/{messageId} {
      allow read, write: if true;
    }
    
    match /{path=**}/transactions/{txId} {
      allow read, write: if true;
    }
    
    match /{path=**}/collections/{colId} {
      allow read, write: if true;
    }
  }
}
