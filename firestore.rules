
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // وظائف مساعدة
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // نفترض أن الأدمن لديه معرف ثابت أو دور مخزن في البروفايل
      // للنموذج الأولي سنسمح لمن لديهم "admin" في البروفايل
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, write: if true; 
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
      
      match /wallet/{doc} {
        allow read, write: if true;
      }
    }
    
    // دعم البحث الشامل في الرسائل (Collection Group) للأدمن
    match /{path=**}/messages/{messageId} {
      allow read: if true; // السماح للأدمن بالاطلاع على كافة الرسائل
    }
    
    match /videos/{videoId} {
      allow read, write: if true;
    }
    
    match /subjects/{subjectId} {
      allow read, write: if true;
      match /collections/{colId} {
        allow read, write: if true;
        match /learning_items/{itemId} {
          allow read, write: if true;
        }
      }
    }
    
    match /products/{productId} {
      allow read, write: if true;
    }
    
    match /offers/{offerId} {
      allow read, write: if true;
    }
    
    match /transactions/{txId} {
      allow read, write: if true;
    }
  }
}
